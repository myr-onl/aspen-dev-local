# =============================================================================
# ASPEN DEV ENVIRONMENT — copy this to .env and fill in your values
# =============================================================================

# Absolute path to your local clone of aspen-discovery on the HOST machine
# macOS example:  /Users/yourname/Git/aspen-discovery
# Windows example: C:\Users\yourname\Git\aspen-discovery
ASPEN_REPO_PATH=/Users/yourname/Git/aspen-discovery

# Uncomment and set where you want to store conf/data/logs on the HOST
# (if different from the default ./sites/{SITE_NAME} path)
# ASPEN_HOME=

# =============================================================================
# SITE SETTINGS
# =============================================================================

# Your personal site identifier — used for directory paths and config filenames
# e.g., dev.localhost, yourname.localhostaspen
SITE_NAME=dev.localhost

# The URL Aspen will use to generate links internally
# Plain HTTP on localhost is the portable default.
URL=http://localhost

TITLE=Aspen Discovery Dev
LIBRARY=Dev Library
SUPPORTING_COMPANY=Dev Haus Myr
TIMEZONE=America/New_York

# Superadmin login password
ASPEN_ADMIN_PASSWORD=secretPass123

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_NAME=aspen
DATABASE_USER=aspendev
DATABASE_PASSWORD=aspendev
DATABASE_ROOT_PASSWORD=root

# =============================================================================
# SERVICES (leave these as-is unless you have port conflicts)
# =============================================================================
SOLR_HOST=solr
SOLR_PORT=8983

HTTP_PORT=80
PHP_FPM_HOST=backend
PHP_FPM_PORT=9000

DB_GUI_PORT=8080

# =============================================================================
# XDEBUG — set XDEBUG_ENABLE=true to turn on, false to leave PHP vanilla
# Your IDE should listen on port 9003 (PhpStorm default)
# =============================================================================
XDEBUG_ENABLE=false
XDEBUG_CLIENT_PORT=9003
# host.docker.internal resolves to your Mac/PC on both OrbStack and Docker Desktop
XDEBUG_CLIENT_HOST=host.docker.internal

# =============================================================================
# IMAGES — leave blank to build locally (recommended for dev)
# Fill these in only if you want to pull pre-built images instead
# =============================================================================
BACKEND_IMAGE_TAG=
SOLR_IMAGE_TAG=
MARIADB_IMAGE=
